# Base URL del deploy de LibreTickets (la app que sirve /post, /checkout, /b...
# y el endpoint publico /api/public/tenant-events del que sale el catalogo).
# En desarrollo local apunta a http://localhost:3000
LIBRETICKETS_BASE_URL=https://app.libretickets.com

# Override del host del tenant para fetch local. En produccion no hace falta:
# Vercel manda x-forwarded-host con el dominio real (icebar.com.br) y
# LibreTickets resuelve la company por su customDomain. En dev local el request
# llega como localhost:3002, asi que necesitamos esta var para apuntar al tenant.
NEXT_PUBLIC_TENANT_HOST=icebar.com.br
